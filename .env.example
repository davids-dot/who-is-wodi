# ===========================================
# 谁是卧底 AI 对战 — 公网部署环境变量模板
# ===========================================
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env

# ---- LLM 云端 API 配置（必填）----

# LLM API 地址（OpenAI 兼容格式，含 /v1 后缀）
# DeepSeek: https://api.deepseek.com/v1
# DashScope: https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_BASE_URL=https://api.deepseek.com/v1

# LLM API 密钥
# DeepSeek: https://platform.deepseek.com/api_keys
# DashScope: https://dashscope.console.aliyun.com/apiKey
LLM_API_KEY=sk-your-api-key-here

# 文本对话模型名称
# DeepSeek: deepseek-chat
# DashScope: qwen-plus
LLM_MODEL_CHAT=deepseek-chat

# LLM 提供商标识（控制 vLLM 扩展参数的传递）
# vllm: 盒子本地模型（传递 chat_template_kwargs）
# deepseek: DeepSeek 云端 API（不传 chat_template_kwargs）
# dashscope: 通义千问云端 API（不传 chat_template_kwargs）
LLM_PROVIDER=deepseek

# ---- 部署模式配置 --------

# Nacos 服务注册（公网部署设为 false）
NACOS_ENABLED=false

# 后端路由前缀（公网模式留空，盒子模式设为 /who-is-wodi）
BASE_PATH=

# 前端构建参数（Docker 构建时传入）
# 公网模式：VITE_BASE_PATH=/, VITE_APP_KEY=
# 盒子模式：VITE_BASE_PATH=/who-is-wodi/, VITE_APP_KEY=who-is-wodi
VITE_BASE_PATH=/
VITE_APP_KEY=

# ---- 可选配置 ----------------

# 服务端口（默认 5201）
# HOST_PORT=5201
# SERVER_PORT=5201
